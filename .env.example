# Resend (https://resend.com): create an API key, then use Contacts for waitlist signups.
# Docs: https://resend.com/docs/api-reference/contacts/create-contact
RESEND_API_KEY=

# Optional: Resend Segment ID to tag waitlist contacts (Dashboard → Segments).
# If unset, contacts are still created globally and visible under Audience → Contacts.
RESEND_SEGMENT_ID=

# Canonical base URL for sitemap, robots, Open Graph URLs (set in Vercel production).
# Example: https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=

# Postgres URL for waitlist rate limits (IP + email). Recommended: Neon free tier (no card).
# Create project at https://neon.tech — run sql/waitlist_rate_limits.sql once in SQL Editor.
# Omit in dev/CI for no-op limits.
WAITLIST_RATE_LIMIT_DATABASE_URL=

# Cloudflare Turnstile - bot check on the waitlist form. Set both or neither (dev skips verify).
# https://developers.cloudflare.com/turnstile/
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Vercel Web Analytics - set to 1 to load @vercel/analytics in the root layout.
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=
