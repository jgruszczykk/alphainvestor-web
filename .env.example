# Resend (https://resend.com): create an API key, then use Contacts for waitlist signups.
# Docs: https://resend.com/docs/api-reference/contacts/create-contact
RESEND_API_KEY=

# Optional: Resend Segment ID to tag waitlist contacts (Dashboard → Segments).
# Sent as segments[] on contact create. If unset, contacts are still created globally.
RESEND_SEGMENT_ID=

# Optional: only if you created a matching Contact Property in Resend (Audience → Properties).
# Example key: signup_locale — without this env, locale is not sent to Resend (avoids 422).
RESEND_SIGNUP_LOCALE_PROPERTY_KEY=

# Optional: verified sender for a short welcome email after a NEW waitlist signup (Resend → Emails).
# Example: Alpha Investor <hello@alphainvestor.app> — domain must be verified in Resend.
# Omit to skip sending email (contact is still created).
RESEND_WELCOME_FROM=

# Optional: origin for links inside the welcome email (/, /#waitlist, /privacy). Defaults to https://www.alphainvestor.pl
RESEND_WELCOME_LINKS_ORIGIN=

# Optional: where user "Reply" goes (your personal or team inbox). Same Resend account; omit = replies follow From.
RESEND_WELCOME_REPLY_TO=

# Canonical base URL for sitemap, robots, Open Graph URLs (set in Vercel production).
# Example: https://www.alphainvestor.app
NEXT_PUBLIC_SITE_URL=

# Postgres URL for waitlist rate limits (IP + email). Recommended: Neon free tier (no card).
# Create project at https://neon.tech — run sql/waitlist_rate_limits.sql once in SQL Editor.
# Omit in dev/CI for no-op limits.
WAITLIST_RATE_LIMIT_DATABASE_URL=

# Cloudflare Turnstile - bot check on the waitlist form. Set both or neither (dev skips verify).
# https://developers.cloudflare.com/turnstile/
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Vercel Web Analytics - set to 1 to load @vercel/analytics in the root layout.
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=
